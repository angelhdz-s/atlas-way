generator client {
  provider = "prisma-client"
  output = "../src/prisma/"
}

datasource db {
  provider = "postgresql"
}

// MARK: User Plan

model Roles {
  id            String        @id
  name          String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          Users[]
}

model Users {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  roleId        String        @default("base")
  role        Roles         @relation(fields: [roleId], references: [id])
  routines      Routines[]
  sessions      Sessions[]
  exercises     Exercises[]
  muscles       Muscles[]
  notifications Notifications[]
  training      Training[]
}

model RoutineCycleTypes {
  id            String          @id
  name          String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  routines      Routines[]
}

model Routines {
  id              String            @id @default(uuid())
  userId          String
  routineCycleId  String
  active          Boolean           @default(true)
  days            Int               @default(7)
  initialDate     DateTime
  name            String
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user          Users             @relation(fields: [userId], references: [id])
  cycleType     RoutineCycleTypes @relation(fields: [routineCycleId], references: [id])
  training        Training[]
  plan            RoutinePlan[]
}

model RoutinePlan {
  id            String        @id @default(uuid())
  routineId     String    
  sessionId     String?   
  name          String    
  dayNumber     Int       
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  routine     Routines      @relation(fields: [routineId], references: [id])
  session     Sessions?     @relation(fields: [sessionId], references: [id])
	@@map("RoutineDays")
}

model Sessions {
  id                String            @id @default(uuid())
  userId            String
  name              String            @unique
  description       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user            Users             @relation(fields: [userId], references: [id])
  plan              RoutinePlan[]
  sessionToExercise SessionsToExercises[]
  training          Training[]
}

model Exercises {
  id            String        @id @default(uuid())
  userId        String
  name          String        
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  reps          Int
  sets          Int
  weight        Int
  user        Users         @relation(fields: [userId], references: [id])
  trainingPlan  TrainingPlan[]
  exercisesToMuscles ExercisesToMuscles[]
  sessionToExercise SessionsToExercises[]
}

// MARK: System tables

model Notifications {
  id              String              @id @default(uuid())
  userId          String
  name            String              
  message         String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            Users             @relation(fields: [userId], references: [id])
}

enum StatusEnum {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

model Status {
  id              StatusEnum              @id
  name            String              @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  trainingSets  TrainingSets[]
}

model DayTypes {
  id              String              @id
  name            String              @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  training        Training[]
}

model BodySections {
  id              Int                 @id @default(autoincrement())
  name            String              @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  muscularGroups  MuscularGroups[]
}

model MuscularGroups {
  id            Int         @id @default(autoincrement())
  bodySectionId Int
  name          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  bodySection   BodySections @relation(fields: [bodySectionId], references: [id])
  muscles       Muscles[]
}

model Muscles {
  id              Int             @id @default(autoincrement())
  muscularGroupId Int
  userId          String
  name            String
  description     String?       
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            Users           @relation(fields: [userId], references: [id])
  muscularGroup   MuscularGroups  @relation(fields: [muscularGroupId], references: [id])
  exercisesToMuscles ExercisesToMuscles[]
}

// MARK: Tracking tables

enum TrainingStatusEnum {
  PENDING
  TARGETS_SET
  IN_PROGRESS
  INTERRUPTED
  COMPLETED
  ABANDONED
}

model TrainingStatus {
  id                    TrainingStatusEnum @id
  name                  String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  training              Training[]
}

model Training {
  id                    String             @id @default(uuid())
  userId                String
  routineId             String?
  sessionId             String?
  date                  DateTime
  statusId              TrainingStatusEnum
  dayTypeId             String
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  user                  Users               @relation(fields: [userId], references: [id])
  dayType               DayTypes            @relation(fields: [dayTypeId], references: [id])
  routine               Routines?            @relation(fields: [routineId], references: [id])
  session               Sessions?            @relation(fields: [sessionId], references: [id])
  status                TrainingStatus              @relation(fields: [statusId], references: [id])
  trainingPlan          TrainingPlan[]
  @@unique([id, routineId, sessionId])
}

model TrainingPlan {
  id                  String       @id @default(uuid())
  trainingId          String       
  exerciseId          String
  sets                Int
  reps                Int
  weight              Int
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  training          Training     @relation(fields: [trainingId], references: [id])
  exercise          Exercises    @relation(fields: [exerciseId], references: [id])
  trainingSets        TrainingSets[]
  @@unique([trainingId, exerciseId])
}

model TrainingSets {
  id                      String                @id @default(uuid())
  trainingPlanId          String                 
  exerciseId              String                 
  set                     Int
  reps                    Int
  weight                  Int
  statusId                StatusEnum
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  trainingPlan          TrainingPlan          @relation(fields: [trainingPlanId], references: [id])
  status                Status                @relation(fields: [statusId], references: [id])
  @@unique([trainingPlanId, exerciseId])
}

/* Link Tables */

model ExercisesToMuscles {
  exerciseId  String    
  muscleId    Int    
  createdAt   DateTime  @default(now())
  exercise    Exercises @relation(fields: [exerciseId], references: [id])
  muscle      Muscles   @relation(fields: [muscleId], references: [id])
  @@id([exerciseId, muscleId])
}

model SessionsToExercises {
  sessionId   String    
  exerciseId  String    
  createdAt   DateTime  @default(now())
  session     Sessions  @relation(fields: [sessionId], references: [id])
  exercise    Exercises @relation(fields: [exerciseId], references: [id])
  @@id([sessionId, exerciseId])
}